{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/titaniumcoder/income-atlas/expenses",
  "title": "Income Atlas Expenses Configuration",
  "description": "Configuration schema for the expense and salary/dividend model used by Income Atlas. Each configuration includes UI metadata plus spreadsheet-like calculation rules. Company income is calculated elsewhere, then configurable rows are applied in four ordered groups. The configuration describes assumptions; it does not configure the search algorithm. The application optimizer always maximizes totalUsableIncome = netSalary + netDividend. Both grossSalary and grossDividend may be fixed, zero, residual, percent-based, or optimized. companyProfit and companyTotal are implicit non-negative invariants: if no explicit minimum is configured, their minimum is 0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "label",
    "title",
    "description",
    "currency",
    "expenseGroups",
    "optimization"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema reference in configuration documents."
    },
    "label": {
      "type": "string",
      "description": "Short UI label for selecting this configuration, for example a tab label or dropdown label. Keep this concise.",
      "minLength": 1,
      "maxLength": 80
    },
    "title": {
      "type": "string",
      "description": "Human-readable title shown as the main heading for this configuration.",
      "minLength": 1,
      "maxLength": 160
    },
    "description": {
      "type": "string",
      "description": "Human-readable explanatory text shown below the title. May contain trusted HTML if the application chooses to render it as HTML; schema validation only treats it as a string.",
      "minLength": 0,
      "maxLength": 8000
    },
    "currency": {
      "type": "string",
      "description": "Main currency for fixed amounts. Use ISO 4217 such as EUR, BGN, RON, CHF.",
      "pattern": "^[A-Z]{3}$"
    },
    "expenseGroups": {
      "type": "object",
      "additionalProperties": false,
      "description": "The four ordered groups used by the model. Rows are freely named; each row declares a calculation type and basis.",
      "required": [
        "companyIncomeExpenses",
        "companyProfitExpenses",
        "grossSalaryExpenses",
        "grossDividendExpenses"
      ],
      "properties": {
        "companyIncomeExpenses": {
          "type": "array",
          "description": "Pre-profit company-side rows. Subtracted from company income before company profit is calculated. Typical rows: fixed business costs, percentage of income, gross-salary-related employer costs.",
          "items": {
            "$ref": "#/$defs/companyIncomeExpenseRow"
          },
          "default": []
        },
        "companyProfitExpenses": {
          "type": "array",
          "description": "Profit-level company rows. Subtracted from company profit. Typical rows: corporate income tax, forced reserve based on profit.",
          "items": {
            "$ref": "#/$defs/companyProfitExpenseRow"
          },
          "default": []
        },
        "grossSalaryExpenses": {
          "type": "array",
          "description": "Personal deductions from gross salary. These reduce gross salary to net salary. Typical rows: employee social contributions, employee health insurance, salary income tax.",
          "items": {
            "$ref": "#/$defs/grossSalaryExpenseRow"
          },
          "default": []
        },
        "grossDividendExpenses": {
          "type": "array",
          "description": "Personal deductions from gross dividend. These reduce gross dividend to net dividend. Typical rows: dividend withholding tax and dividend-related health/social charges.",
          "items": {
            "$ref": "#/$defs/grossDividendExpenseRow"
          },
          "default": []
        }
      }
    },
    "optimization": {
      "type": "object",
      "additionalProperties": false,
      "description": "Defines how gross salary and gross dividend are determined. The objective is not configurable: the application maximizes totalUsableIncome = netSalary + netDividend whenever one or both gross amounts are optimized. If neither gross amount is optimized, the configuration is just evaluated as a calculation. The search strategy, candidate generation, cap probing, refinement, and caching are application concerns, not schema fields.",
      "required": [
        "grossSalary",
        "grossDividend"
      ],
      "properties": {
        "grossSalary": {
          "$ref": "#/$defs/grossSalaryRule"
        },
        "grossDividend": {
          "$ref": "#/$defs/grossDividendRule"
        },
        "minimums": {
          "type": "object",
          "description": "Optional minimum result constraints. Omitted minimums are disabled, except companyProfit and companyTotal: these are special model invariants with an implicit minimum of 0. These are lower bounds, not optimization targets.",
          "additionalProperties": false,
          "properties": {
            "totalUsableIncome": {
              "$ref": "#/$defs/minimumRule"
            },
            "grossDividend": {
              "$ref": "#/$defs/minimumRule"
            },
            "grossSalary": {
              "$ref": "#/$defs/minimumRule"
            },
            "companyTotal": {
              "$ref": "#/$defs/minimumRule"
            },
            "companyProfit": {
              "$ref": "#/$defs/minimumRule"
            }
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional hard constraints. Omitted constraints are disabled.",
      "properties": {
        "minimumGrossSalary": {
          "$ref": "#/$defs/minimumRule",
          "description": "Optional lower bound for gross salary. Useful for immigration, legal, or practical minimum salary assumptions."
        },
        "maximumDividendToSalaryPercent": {
          "$ref": "#/$defs/percentage",
          "description": "Optional maximum gross dividend as percent of gross salary. Omitted means disabled. Example: 10 means gross dividend may not exceed 10% of gross salary."
        }
      }
    }
  },
  "$defs": {
    "nonEmptyName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Human-readable row name. Names are free-form."
    },
    "nonNegativeMoneyAmount": {
      "type": "number",
      "minimum": 0,
      "description": "Non-negative money amount in the configuration currency."
    },
    "positiveMoneyAmount": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Positive money amount in the configuration currency."
    },
    "percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Percentage between 0 and 100. Use 10 for 10%, not 0.10."
    },
    "basis": {
      "type": "string",
      "enum": [
        "companyIncome",
        "companyProfit",
        "grossSalary",
        "grossDividend"
      ]
    },
    "rowCommon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "calculation"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyName"
        },
        "description": {
          "type": "string",
          "maxLength": 2000
        },
        "calculation": {
          "oneOf": [
            {
              "$ref": "#/$defs/fixMonthCalculation"
            },
            {
              "$ref": "#/$defs/fixYearCalculation"
            },
            {
              "$ref": "#/$defs/percentCalculation"
            },
            {
              "$ref": "#/$defs/percentBelowCapCalculation"
            },
            {
              "$ref": "#/$defs/percentAboveCapCalculation"
            }
          ]
        }
      }
    },
    "fixMonthCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "amount"
      ],
      "properties": {
        "type": {
          "const": "fixMonth"
        },
        "amount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "fixYearCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "amount"
      ],
      "properties": {
        "type": {
          "const": "fixYear"
        },
        "amount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "percentCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent"
      ],
      "properties": {
        "type": {
          "const": "percent"
        },
        "basis": {
          "$ref": "#/$defs/basis"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        }
      }
    },
    "percentBelowCapCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent",
        "capAmount"
      ],
      "properties": {
        "type": {
          "const": "percentBelowCap"
        },
        "basis": {
          "$ref": "#/$defs/basis"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        },
        "capAmount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "percentAboveCapCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent",
        "capAmount"
      ],
      "properties": {
        "type": {
          "const": "percentAboveCap"
        },
        "basis": {
          "$ref": "#/$defs/basis"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        },
        "capAmount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "companyIncomeExpenseRow": {
      "allOf": [
        {
          "$ref": "#/$defs/rowCommon"
        },
        {
          "properties": {
            "calculation": {
              "oneOf": [
                {
                  "$ref": "#/$defs/fixMonthCalculation"
                },
                {
                  "$ref": "#/$defs/fixYearCalculation"
                },
                {
                  "$ref": "#/$defs/companyIncomeOrSalaryPercentCalculation"
                },
                {
                  "$ref": "#/$defs/companyIncomeOrSalaryPercentBelowCapCalculation"
                },
                {
                  "$ref": "#/$defs/companyIncomeOrSalaryPercentAboveCapCalculation"
                }
              ]
            }
          }
        }
      ]
    },
    "companyProfitExpenseRow": {
      "allOf": [
        {
          "$ref": "#/$defs/rowCommon"
        },
        {
          "properties": {
            "calculation": {
              "oneOf": [
                {
                  "$ref": "#/$defs/fixMonthCalculation"
                },
                {
                  "$ref": "#/$defs/fixYearCalculation"
                },
                {
                  "$ref": "#/$defs/companyProfitPercentCalculation"
                },
                {
                  "$ref": "#/$defs/companyProfitPercentBelowCapCalculation"
                },
                {
                  "$ref": "#/$defs/companyProfitPercentAboveCapCalculation"
                }
              ]
            }
          }
        }
      ]
    },
    "grossSalaryExpenseRow": {
      "allOf": [
        {
          "$ref": "#/$defs/rowCommon"
        },
        {
          "properties": {
            "calculation": {
              "oneOf": [
                {
                  "$ref": "#/$defs/fixMonthCalculation"
                },
                {
                  "$ref": "#/$defs/fixYearCalculation"
                },
                {
                  "$ref": "#/$defs/grossSalaryPercentCalculation"
                },
                {
                  "$ref": "#/$defs/grossSalaryPercentBelowCapCalculation"
                },
                {
                  "$ref": "#/$defs/grossSalaryPercentAboveCapCalculation"
                }
              ]
            }
          }
        }
      ]
    },
    "grossDividendExpenseRow": {
      "allOf": [
        {
          "$ref": "#/$defs/rowCommon"
        },
        {
          "properties": {
            "calculation": {
              "oneOf": [
                {
                  "$ref": "#/$defs/fixMonthCalculation"
                },
                {
                  "$ref": "#/$defs/fixYearCalculation"
                },
                {
                  "$ref": "#/$defs/grossDividendPercentCalculation"
                },
                {
                  "$ref": "#/$defs/grossDividendPercentBelowCapCalculation"
                },
                {
                  "$ref": "#/$defs/grossDividendPercentAboveCapCalculation"
                }
              ]
            }
          }
        }
      ]
    },
    "companyIncomeOrSalaryBasis": {
      "type": "string",
      "enum": [
        "companyIncome",
        "grossSalary"
      ]
    },
    "companyIncomeOrSalaryPercentCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent"
      ],
      "properties": {
        "type": {
          "const": "percent"
        },
        "basis": {
          "$ref": "#/$defs/companyIncomeOrSalaryBasis"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        }
      }
    },
    "companyIncomeOrSalaryPercentBelowCapCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent",
        "capAmount"
      ],
      "properties": {
        "type": {
          "const": "percentBelowCap"
        },
        "basis": {
          "$ref": "#/$defs/companyIncomeOrSalaryBasis"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        },
        "capAmount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "companyIncomeOrSalaryPercentAboveCapCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent",
        "capAmount"
      ],
      "properties": {
        "type": {
          "const": "percentAboveCap"
        },
        "basis": {
          "$ref": "#/$defs/companyIncomeOrSalaryBasis"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        },
        "capAmount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "companyProfitPercentCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent"
      ],
      "properties": {
        "type": {
          "const": "percent"
        },
        "basis": {
          "const": "companyProfit"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        }
      }
    },
    "companyProfitPercentBelowCapCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent",
        "capAmount"
      ],
      "properties": {
        "type": {
          "const": "percentBelowCap"
        },
        "basis": {
          "const": "companyProfit"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        },
        "capAmount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "companyProfitPercentAboveCapCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent",
        "capAmount"
      ],
      "properties": {
        "type": {
          "const": "percentAboveCap"
        },
        "basis": {
          "const": "companyProfit"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        },
        "capAmount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "grossSalaryPercentCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent"
      ],
      "properties": {
        "type": {
          "const": "percent"
        },
        "basis": {
          "const": "grossSalary"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        }
      }
    },
    "grossSalaryPercentBelowCapCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent",
        "capAmount"
      ],
      "properties": {
        "type": {
          "const": "percentBelowCap"
        },
        "basis": {
          "const": "grossSalary"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        },
        "capAmount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "grossSalaryPercentAboveCapCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent",
        "capAmount"
      ],
      "properties": {
        "type": {
          "const": "percentAboveCap"
        },
        "basis": {
          "const": "grossSalary"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        },
        "capAmount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "grossDividendPercentCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent"
      ],
      "properties": {
        "type": {
          "const": "percent"
        },
        "basis": {
          "const": "grossDividend"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        }
      }
    },
    "grossDividendPercentBelowCapCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent",
        "capAmount"
      ],
      "properties": {
        "type": {
          "const": "percentBelowCap"
        },
        "basis": {
          "const": "grossDividend"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        },
        "capAmount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "grossDividendPercentAboveCapCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "basis",
        "percent",
        "capAmount"
      ],
      "properties": {
        "type": {
          "const": "percentAboveCap"
        },
        "basis": {
          "const": "grossDividend"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        },
        "capAmount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "minimumRule": {
      "oneOf": [
        {
          "$ref": "#/$defs/minimumFixedRule"
        },
        {
          "$ref": "#/$defs/minimumPercentOfCompanyIncomeRule"
        }
      ]
    },
    "minimumFixedRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "amount"
      ],
      "properties": {
        "type": {
          "const": "fixed"
        },
        "amount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "minimumPercentOfCompanyIncomeRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "percent"
      ],
      "properties": {
        "type": {
          "const": "percentOfCompanyIncome"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        }
      }
    },
    "grossSalaryRule": {
      "oneOf": [
        {
          "$ref": "#/$defs/grossAmountZeroRule"
        },
        {
          "$ref": "#/$defs/grossAmountFixedRule"
        },
        {
          "$ref": "#/$defs/grossAmountPercentOfCompanyIncomeRule"
        },
        {
          "$ref": "#/$defs/grossAmountOptimizedRule"
        },
        {
          "$ref": "#/$defs/grossAmountResidualRule"
        }
      ]
    },
    "grossDividendRule": {
      "oneOf": [
        {
          "$ref": "#/$defs/grossAmountZeroRule"
        },
        {
          "$ref": "#/$defs/grossAmountFixedRule"
        },
        {
          "$ref": "#/$defs/grossAmountPercentOfCompanyIncomeRule"
        },
        {
          "$ref": "#/$defs/grossAmountOptimizedRule"
        },
        {
          "$ref": "#/$defs/grossAmountResidualRule"
        }
      ]
    },
    "grossAmountZeroRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "zero"
        }
      }
    },
    "grossAmountFixedRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "amount"
      ],
      "properties": {
        "type": {
          "const": "fixed"
        },
        "amount": {
          "$ref": "#/$defs/nonNegativeMoneyAmount"
        }
      }
    },
    "grossAmountPercentOfCompanyIncomeRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "percent"
      ],
      "properties": {
        "type": {
          "const": "percentOfCompanyIncome"
        },
        "percent": {
          "$ref": "#/$defs/percentage"
        }
      }
    },
    "grossAmountOptimizedRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "optimized"
        },
        "minimum": {
          "$ref": "#/$defs/minimumRule"
        },
        "maximum": {
          "$ref": "#/$defs/minimumRule"
        }
      }
    },
    "grossAmountResidualRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "residual"
        },
        "description": {
          "type": "string",
          "maxLength": 1000
        }
      },
      "description": "Use the remaining available amount after earlier calculation stages and invariants are applied. Application logic defines the exact residual direction for salary or dividend."
    }
  }
}
